{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pomodoro-timer",
  "version": "1.0.1",
  "identifier": "com.pomodoro.timer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Pomodoro",
        "width": 400,
        "height": 600,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
